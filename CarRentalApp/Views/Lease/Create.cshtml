@model Models.Lease
@{
    ViewData["Title"] = "Set Duration";
   
    var vehicle = ViewBag.Vehicle as Models.Vehicle;
}

<div class="container mt-4">
    <h2>Set Your Lease Duration</h2>
    <hr />

    @if (vehicle != null)
    {
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h4 class="card-title">@vehicle.Brand @vehicle.Model</h4>
                <p class="text-muted">Year: @vehicle.Year</p>
            
                <p><strong>Standard Daily Rate:</strong> $@vehicle.DailyRate.ToString("F2")</p>

                <p><strong>Calculated Hourly Rate:</strong> $@(((double)vehicle.DailyRate / 24.0).ToString("F2"))</p>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <form asp-action="ProceedToCustomer" method="post">
              
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="vehicleId" value="@vehicle.VehicleID" />

                    <div class="form-group mb-3">
                        <label class="form-label">How many hours would you like to rent?</label>
                        <input type="number" name="hours" id="inputHours" class="form-control" min="1" max="240" required />
                    </div>

                    <div class="alert alert-info">
                        <h5>Total Estimated Price: $<span id="displayPrice">0.00</span></h5>
                    </div>

                    <button type="submit" class="btn btn-success w-100">Confirm Hours & Enter Details</button>
                </form>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-danger">Vehicle details could not be loaded. Please go back and try again.</div>
    }
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function () {
        $("#inputHours").on("input", function () {
            var hours = $(this).val();

            if (hours > 0) {
            
                $.get("/Vehicle/CalculatePrice", { vehicleId: '@(vehicle?.VehicleID)', hours: hours }, function (data) {
                    var price = parseFloat(data);
                    $("#displayPrice").text(price.toFixed(2));
                });
            } else {
                $("#displayPrice").text("0.00");
            }
        });
    });
</script>