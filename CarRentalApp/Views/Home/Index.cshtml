@{
    ViewData["Title"] = "Home Page";
}

<style>
    .carousel-frame {
        padding: 40px; 
        max-width: 1300px;
        margin: 0 auto;
    }

   
    .custom-carousel {
        height: 75vh; 
        border-radius: 25px;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0,0,0,0.25);
        position: relative;
    }

    .carousel-inner, .carousel-item, .carousel-item img {
        height: 100%;
    }

        .carousel-item img {
            object-fit: cover;
            object-position: center;
        }

    
    .carousel-control-prev, .carousel-control-next {
        width: 8%; 
        transition: opacity 0.3s ease;
    }

    .carousel-control-prev-icon, .carousel-control-next-icon {
        background-color: rgba(0,0,0,0.5); 
        background-size: 50% 50%;
        border-radius: 50%;
        padding: 25px;
    }

    /* 4. Styled Indicators (Dots) */
    .carousel-indicators [button] {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        margin: 0 6px;
    }

    /* 5. Glassmorphism Caption */
    .carousel-caption {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 20px;
        padding: 25px;
        bottom: 8%;
        max-width: 70%;
        left: 15%;
    }
</style>

<div class="carousel-frame">
    <div id="carRentalCarousel" class="carousel slide custom-carousel carousel-fade" data-bs-ride="carousel">

        <div class="carousel-indicators">
            <button type="button" data-bs-target="#carRentalCarousel" data-bs-slide-to="0" class="active" aria-current="true"></button>
            <button type="button" data-bs-target="#carRentalCarousel" data-bs-slide-to="1"></button>
            <button type="button" data-bs-target="#carRentalCarousel" data-bs-slide-to="2"></button>
        </div>

        <div class="carousel-inner">
            <div class="carousel-item active">
                <img src="https://images.unsplash.com/photo-1503376780353-7e6692767b70?auto=format&fit=crop&w=1200&q=80" class="d-block w-100" alt="Premium Cars">
                <div class="carousel-caption d-none d-md-block">
                    <h2 class="fw-bold">Premium Collection</h2>
                    <p class="fs-5">Drive the latest models from top brands starting at Rs.49/day.</p>
                </div>
            </div>

            <div class="carousel-item">
                <img src="https://images.unsplash.com/photo-1533473359331-0135ef1b58bf?auto=format&fit=crop&w=1200&q=80" class="d-block w-100" alt="Adventure">
                <div class="carousel-caption d-none d-md-block">
                    <h2 class="fw-bold">Ready for Adventure</h2>
                    <p class="fs-5">Robust SUVs for your weekend getaway or family road trip.</p>
                </div>
            </div>

            <div class="carousel-item">
                <img src="https://images.unsplash.com/photo-1594535182308-8ffefbb661e1?auto=format&fit=crop&w=1200&q=80" class="d-block w-100" alt="Electric">
                <div class="carousel-caption d-none d-md-block">
                    <h2 class="fw-bold">The Future is Electric</h2>
                    <p class="fs-5">Eco-friendly travel with our new fleet of Tesla and Rivian models.</p>
                </div>
            </div>
        </div>

        <button class="carousel-control-prev" type="button" data-bs-target="#carRentalCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#carRentalCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>
    </div>
</div>