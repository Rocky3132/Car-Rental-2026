@model IEnumerable<Models.Vehicle>
<h2>Fleet Management</h2>
<p><a asp-action="Create" class="btn btn-primary">Add New Vehicle</a></p>
<table class="table">
    <thead>
        <tr>
            <th>Brand</th>
            <th>Model</th>
            <th>Daily Rate</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Brand</td>
                <td>@item.Model</td>
                <td>@item.DailyRate</td>
                <td><span class="badge @(item.Status == "Available" ? "bg-success" : "bg-danger")">@item.Status</span></td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.VehicleID">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@item.VehicleID">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>