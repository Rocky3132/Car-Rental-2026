@model Models.Vehicle

@{
    ViewData["Title"] = "Delete Vehicle";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger shadow">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0"><i class="fa fa-exclamation-triangle"></i> Confirm Deletion</h4>
                </div>
                <div class="card-body">
                    @if (Model != null)
                    {
                        <h5 class="card-title text-center mb-3">Are you sure you want to remove this car?</h5>
                        <div class="bg-light p-3 rounded">
                            <h4 class="text-center">@Model.Brand @Model.Model</h4>
                            <hr />
                            <dl class="row mb-0">
                                <dt class="col-sm-5">Year:</dt>
                                <dd class="col-sm-7">@Model.Year</dd>

                                <dt class="col-sm-5">Daily Rate:</dt>
                              
                                <dd class="col-sm-7 text-success fw-bold">$@Model.DailyRate.ToString("F2")</dd>

                                <dt class="col-sm-5">Status:</dt>
                                <dd class="col-sm-7">
                                    <span class="badge @(Model.Status == "Available" ? "bg-success" : "bg-danger")">
                                        @Model.Status
                                    </span>
                                </dd>
                            </dl>
                        </div>

                        <form asp-action="Delete" method="post" class="mt-4">
                            @Html.AntiForgeryToken()
                            <input type="hidden" asp-for="VehicleID" />
                            <div class="d-flex justify-content-between">
                                <a asp-action="Index" class="btn btn-secondary px-4">
                                    <i class="fa fa-arrow-left"></i> Cancel
                                </a>
                                <button type="submit" class="btn btn-danger px-4">
                                    <i class="fa fa-trash"></i> Confirm Delete
                                </button>
                            </div>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-warning">
                            Vehicle not found. It may have already been deleted.
                        </div>
                        <a asp-action="Index" class="btn btn-primary w-100">Return to Fleet</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>