@model Models.Vehicle

<h2>Delete Vehicle</h2>
<h4 class="text-danger">Are you sure you want to delete this car?</h4>

<div class="card mt-4">
    <div class="card-body">
        <h5>@Model.Brand @Model.Model</h5>
        <hr />
        <dl class="row">
            <dt class="col-sm-3">Year</dt>
            <dd class="col-sm-9">@Model.Year</dd>

            <dt class="col-sm-3">Daily Rate</dt>
            <dd class="col-sm-9">$@Model.DailyRate</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="VehicleID" />
    <button type="submit" class="btn btn-danger">Confirm Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>