@model Models.Vehicle

<h2>Edit Vehicle</h2>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="VehicleID" />

    <div class="form-group mb-3">
        <label asp-for="Brand" class="form-label"></label>
        <input asp-for="Brand" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label asp-for="Model" class="form-label"></label>
        <input asp-for="Model" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label asp-for="Year" class="form-label"></label>
        <input asp-for="Year" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label asp-for="DailyRate" class="form-label"></label>
        <input asp-for="DailyRate" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label asp-for="Status" class="form-label"></label>
        <select asp-for="Status" class="form-control">
            <option value="Available">Available</option>
            <option value="Rented">Rented</option>
            <option value="Maintenance">Maintenance</option>
        </select>
    </div>

    <div class="form-group mb-3">
        <label asp-for="PassengerCapacity" class="form-label"></label>
        <input asp-for="PassengerCapacity" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label asp-for="EngineCapacity" class="form-label"></label>
        <input asp-for="EngineCapacity" class="form-control" />
    </div>

    <button type="submit" class="btn btn-warning">Save Changes</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>