@model IEnumerable<Models.Payment>

@{
    ViewData["Title"] = "Payment History";
}

<div class="container mt-4">
    <div class="card shadow border-0">
        <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0"><i class="bi bi-currency-dollar"></i> Financial History</h4>
            <h5 class="mb-0">Total Revenue: $@Model.Sum(p => p.Amount).ToString("F2")</h5>
        </div>
        <div class="card-body">
            <table class="table table-striped align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Date</th>
                        <th>Customer</th>
                        <th>Vehicle</th>
                        <th>Duration</th>
                        <th>Amount</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.PaymentDate.ToString("MMM dd, yyyy HH:mm")</td>
                            <td>@item.Lease.Customer.FirstName @item.Lease.Customer.LastName</td>
                            <td>@item.Lease.Vehicle.Brand @item.Lease.Vehicle.Model</td>
                            <td>
                                @{
                                    var hours = (item.Lease.EndDate - item.Lease.StartDate).TotalHours;
                                    @hours.ToString("F1") @:hrs
                                }
                            </td>
                            <td class="fw-bold text-success">$@item.Amount.ToString("F2")</td>
                            <td><span class="badge bg-success">Paid</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>