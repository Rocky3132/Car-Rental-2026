@model IEnumerable<Models.Payment>

@{
    ViewData["Title"] = "Payment History";
}

<div class="container mt-4">
    <div class="card shadow border-0">
        <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0"><i class="bi bi-currency-dollar"></i> Financial History</h4>
            @* Fix: Ensure Sum handles nulls if model is empty *@
            <h5 class="mb-0">Total Revenue: $@(Model?.Sum(p => p.Amount).ToString("F2") ?? "0.00")</h5>
        </div>
        <div class="card-body">
            <table class="table table-striped align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Date</th>
                        <th>Customer</th>
                        <th>Vehicle</th>
                        <th>Duration</th>
                        <th>Amount</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                         
                                <td>@(item.PaymentDate?.ToString("MMM dd, yyyy HH:mm") ?? "N/A")</td>

                                <td>@(item.Lease?.Customer?.FirstName) @(item.Lease?.Customer?.LastName)</td>
                                <td>@(item.Lease?.Vehicle?.Brand) @(item.Lease?.Vehicle?.Model)</td>

                                <td>
                                    @{
                                    
                                        if (item.Lease?.StartDate != null && item.Lease?.EndDate != null)
                                        {
                                            var hours = (item.Lease.EndDate.Value - item.Lease.StartDate.Value).TotalHours;
                                            <span>@hours.ToString("F1") hrs</span>
                                        }
                                        else
                                        {
                                            <span>N/A</span>
                                        }
                                    }
                                </td>

                                <td class="fw-bold text-success">$@item.Amount.ToString("F2")</td>
                                <td><span class="badge bg-success">Paid</span></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted">No financial records found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>